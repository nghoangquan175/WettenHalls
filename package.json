{
  "name": "wetten-halls-root",
  "version": "1.0.0",
  "description": "Root folder for WettenHalls project to run frontend and backend together",
  "scripts": {
    "dev:frontend": "npm run dev --prefix frontend-next",
    "dev:backend": "npm run dev --prefix backend-strapi",
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
